{
  "name": "pagwebprod",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "mock:api": "node mock-server.js",
    "test": "ng test",
    "serve:ssr:pagwebprod": "node dist/pagwebprod/server/server.mjs",
    "api": "ts-node --transpile-only api-server.ts",
    "dev": "concurrently \"npm run start\" \"npm run api\""
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.0",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "concurrently": "^10.0.3",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}